# ============================================================
# Telegram Bot
# ============================================================
BOT_TOKEN=                       # BotFather → /newbot
OWNER_CHAT_ID=                   # ваш числовой Telegram ID

# ============================================================
# Gemini
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash    # опционально

# ============================================================
# Google Sheets
# ============================================================
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_B64=          # base64 от service account JSON

# ============================================================
# Lava.top (карточная оплата — RUB/USD/EUR)
# ============================================================
# 1. Зарегистрируйтесь на lava.top
# 2. Создайте продукт (Контент → Добавить продукт)
# 3. Интеграции → API → Создать ключ → скопируйте
LAVA_API_KEY=

# 4. На той же странице: три точки → Добавить Webhook
#    URL: https://<your-railway-domain>/lava-webhook
#    Тип события: Результат платежа
#    Авторизация: API Key → введите любой секрет → скопируйте сюда
LAVA_WEBHOOK_SECRET=

# 5. Ваш продукт → Настройки → скопируйте UUID
LAVA_OFFER_ID=

# ============================================================
# Crypto Bot (крипто-оплата — USDT/TON/BTC/...)
# ============================================================
# 1. https://t.me/CryptoBot → /pay → Создать приложение
# 2. Скопируйте API Token
CRYPTO_BOT_TOKEN=
# Для тестирования: https://t.me/CryptoTestnetBot → тот же путь
CRYPTO_BOT_TESTNET=false

# ============================================================
# Webhook сервер (для Lava)
# ============================================================
# Railway автоматически выставляет PORT — обычно не нужно менять
WEBHOOK_PORT=8080

# Домен для синтетических email (если клиент не указал email)
DEFAULT_EMAIL_DOMAIN=tg.placeholder.com

# ============================================================
# Уведомления (опционально)
# ============================================================
TRIAL_WARN_DAYS=1
SUBSCRIPTION_WARN_DAYS=3
SCHEDULER_HOUR=10
