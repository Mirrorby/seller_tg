# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather
OWNER_CHAT_ID=your_telegram_user_id  # числовой ID, узнать через @userinfobot

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash  # опционально, по умолчанию gemini-1.5-flash

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id  # из URL таблицы: /spreadsheets/d/ЭТОТ_ID/edit
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}  # весь JSON одной строкой

# Настройки уведомлений (опционально)
# TRIAL_WARN_DAYS=1        # за сколько дней предупреждать об окончании триала
# SUBSCRIPTION_WARN_DAYS=3 # за сколько дней предупреждать об окончании подписки
# SCHEDULER_HOUR=10        # в какой час UTC запускать проверку (10 UTC = 14:00 Батуми)
